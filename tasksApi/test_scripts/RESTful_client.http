# Tasks API - RESTful Client Tests
# Copy this file to IntelliJ and run as HTTP Client, or import to Postman

### ======================================================
### AUTH CONTROLLER
### ======================================================

### 1. Signup Admin
POST http://localhost:8080/api/auth/signup
Content-Type: application/json

{
  "displayName": "System Administrator",
  "username": "admin",
  "password": "admin123",
  "role": "ADMIN",
  "department": "IT"
}

### 2. Signup Manager
POST http://localhost:8080/api/auth/signup
Content-Type: application/json

{
  "displayName": "Test Manager",
  "username": "manager",
  "password": "manager123",
  "role": "MANAGER",
  "department": "HR"
}

### 3. Signup User
POST http://localhost:8080/api/auth/signup
Content-Type: application/json

{
  "displayName": "Test User",
  "username": "user",
  "password": "user123",
  "role": "USER",
  "department": "Sales"
}

### 4. Signin Admin
POST http://localhost:8080/api/auth/signin
Content-Type: application/json

{
  "username": "admin",
  "password": "admin123"
}

### 5. Signin Manager
POST http://localhost:8080/api/auth/signin
Content-Type: application/json

{
  "username": "manager",
  "password": "manager123"
}

### 6. Signin User
POST http://localhost:8080/api/auth/signin
Content-Type: application/json

{
  "username": "user",
  "password": "user123"
}

### ======================================================
### TEST CONTROLLER (Public Endpoints)
### ======================================================

### 7. Public Endpoint (No Auth Required)
GET http://localhost:8080/api/test/public

### 8. User Endpoint (Requires USER role)
GET http://localhost:8080/api/test/user
Authorization: Bearer {{adminToken}}

### 9. Admin Endpoint (Requires ADMIN role)
GET http://localhost:8080/api/test/admin
Authorization: Bearer {{adminToken}}

### ======================================================
### USER CONTROLLER
### ======================================================

### 10. Get All Users by Role - USER
GET http://localhost:8080/api/users/role/USER
Authorization: Bearer {{adminToken}}

### 11. Get All Users by Role - MANAGER
GET http://localhost:8080/api/users/role/MANAGER
Authorization: Bearer {{adminToken}}

### 12. Get All Users by Role - ADMIN
GET http://localhost:8080/api/users/role/ADMIN
Authorization: Bearer {{adminToken}}

### 13. Get Enabled Users by Role - USER
GET http://localhost:8080/api/users/role/USER/enabled/true
Authorization: Bearer {{adminToken}}

### 14. Get Disabled Users by Role - USER
GET http://localhost:8080/api/users/role/USER/enabled/false
Authorization: Bearer {{adminToken}}

### 15. Disable User (Set enabled=false)
PUT http://localhost:8080/api/users/3/enable?enabled=false
Authorization: Bearer {{adminToken}}

### 14. Enable User (Set enabled=true)
PUT http://localhost:8080/api/users/3/enable?enabled=true
Authorization: Bearer {{adminToken}}

### 15. Delete User by ID
DELETE http://localhost:8080/api/users/3
Authorization: Bearer {{adminToken}}

### 16. Change Password
PUT http://localhost:8080/api/users/change-password
Content-Type: application/json
Authorization: Bearer {{adminToken}}

{
  "currentPassword": "admin123",
  "newPassword": "newpassword123"
}

### 17. Forgot Password (Reset Password)
POST http://localhost:8080/api/auth/forgot-password
Content-Type: application/json

{
  "username": "admin",
  "newPassword": "resetpassword123"
}

### ======================================================
### APPS CONTROLLER
### ======================================================

### 18. Create New App
POST http://localhost:8080/api/apps
Content-Type: application/json
Authorization: Bearer {{adminToken}}

{
  "appName": "Test Application"
}

### 19. Get All Apps
GET http://localhost:8080/api/apps
Authorization: Bearer {{adminToken}}

### 20. Get App by ID
GET http://localhost:8080/api/apps/1
Authorization: Bearer {{adminToken}}

### 21. Update App by ID
PUT http://localhost:8080/api/apps/1
Content-Type: application/json
Authorization: Bearer {{adminToken}}

{
  "appName": "Updated Application Name"
}

### 22. Delete App by ID
DELETE http://localhost:8080/api/apps/1
Authorization: Bearer {{adminToken}}

### ======================================================
### USER CONTROLLER - ROLES LISTING
### ======================================================

### 23. Get All Roles
GET http://localhost:8080/api/users/roles
Authorization: Bearer {{adminToken}}

